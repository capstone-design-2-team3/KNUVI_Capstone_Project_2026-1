    {
      \"cell_type\": \"code\",
      \"source\": [
        \"DIR_BASE = '/content/drive/MyDrive/Research/26_Capstone2'\\n\\nMETHODS = [\\\"LongSplat\\\", \\\"3DGS\\\"]\\nCONDITIONS = [\\\"original\\\", \\\"snow\\\", \\\"de_snow\\\"]\\n\\n# \\\"grass\\\", \\\"hydrant\\\", \\\"pillar\\\", \\\"road\\\", \\\"sky\\\", \\\"stair\\\"\\nSCENES = [\\n    \\\"grass\\\", \\n    \\\"pillar\\\", \\n    \\\"road\\\"\\n]\\n\\n# GT 디렉토리 리스트 생성\\nGT_DIR_LIST = [os.path.join(DIR_BASE, \\\"GT\\\", f\\\"gt_{s}\\\") for s in SCENES]\\n\\n# 각 Scene별 예측 디렉토리 그룹 생성\\nSCENE_LIST = [\\n    [os.path.join(DIR_BASE, m, f\\\"{s}_{c}\\\") for m in METHODS for c in CONDITIONS]\\n    for s in SCENES\\n]\\n\\n# Scene별 세부 디렉토리 탐색\\nfor i in range(len(SCENE_LIST)):\\n    for j in range(len(SCENE_LIST[i])):\\n        SCENE_LIST[i][j] = find_render_dir(SCENE_LIST[i][j])\\n\\n# Dir List 생성결과 확인\\nprint(\\\"=== GT Directory List ===\\\")\\nfor gt in GT_DIR_LIST:\\n    print(gt)\\n\\nprint(\\\"\\\\n=== Prediction Directory List (by Scene) ===\\\")\\nfor idx, scene_paths in enumerate(SCENE_LIST):\\n    print(f\\\"\\\\nScene: {SCENES[idx]}\\\")\\n    for path in scene_paths:\\n        print(f\\\"  - {path}\\\")\"
      ],
      \"metadata\": {
        \"id\": \"GwjyY5k1x6Gh\"
      },
      \"execution_count\": null,
