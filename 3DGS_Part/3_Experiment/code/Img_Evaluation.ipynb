    },
    {
      \"cell_type\": \"code\",
      \"source\": [
        \"import pandas as pd\\n\\nresults = []\\n\\nfor i, (gt_dir, pred_group) in enumerate(zip(GT_DIR_LIST, SCENE_LIST)):\\n    scene_name = SCENES[i]\\n    print(f\\\"\\\\n==============================\\\")\\n    print(f\\\"GT: {gt_dir}\\\")\\n\\n    if not os.path.exists(gt_dir):\\n            print(f\\\"GT 폴더를 찾을 수 없음, 스킵: {gt_dir}\\\")\\n            continue\\n\\n    path_idx = 0\\n    for m_name in METHODS:\\n        for c_name in CONDITIONS:\\n            pred_dir = pred_group[path_idx]\\n            path_idx += 1\\n\\n            print(f\\\"PRED ({m_name} - {c_name}): {pred_dir}\\\")\\n\\n            if not os.path.exists(pred_dir):\\n                print(f\\\"PRED 폴더를 찾을 수 없음, 스킵: {pred_dir}\\\")\\n                continue\\n\\n            try:\\n                # 지표 계산 실행 (에러 발생 시 스킵)\n                metrics = compute_all_metrics(gt_dir, pred_dir, save_crops=True)\\n\\n                if metrics:\\n                    psnr, ssim, lpips_val = metrics\\n                    results.append({\\n                        'Scene': scene_name,\\n                        'Method': m_name,\\n                        'Condition': c_name,\\n                        'PSNR': psnr,\\n                        'SSIM': ssim,\\n                        'LPIPS': lpips_val\\n                    })\\n            except Exception as e:\\n                print(f\\\"Error computing metrics for {pred_dir}: {e}\\\")\\n                print(\\\"다음 결과로 넘어갑니다.\\\")\\n                continue\\n            print()\\n\\n# CSV 저장\\nif results:\\n    df = pd.DataFrame(results)\\n    csv_path = os.path.join(DIR_BASE, 'metrics_results.csv')\\n    df.to_csv(csv_path, index=False)\\n    print(f\\\"\\\\n[DONE] All metrics saved to: {csv_path}\\\")\\n    display(df)\"
